---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemePreview from "../components/ThemePreview.astro";
import Palette from "../components/Palette.astro";
import ApplicationPreviews from "../components/ApplicationPreviews.astro";
import { applications } from "../lib/applications";
import { getThemes } from "../lib/themes";
import { samples } from "../lib/samples";
import { codeToHtml } from "shiki";

const themes = await getThemes();
const featuredTheme = themes[0];
const highlightedSamples = await Promise.all(
  samples.map(async (sample) => ({
    ...sample,
    html: await codeToHtml(sample.code, {
      lang: sample.language,
      theme: featuredTheme.shikiTheme
    })
  }))
);
---

<BaseLayout>
  <main class="page-shell">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Yotei theme</p>
        <h1>Preview the dawn before installing it.</h1>
        <p>
          Explore Yotei directly in the browser with real colors loaded from the
          VS Code theme files, plus previews for supported applications.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={`/themes/${featuredTheme.slug}`}>Open full preview</a>
          <a class="button secondary" href="https://github.com/bzenky/yotei" target="_blank" rel="noreferrer">View on GitHub</a>
        </div>
      </div>
      <ThemePreview theme={featuredTheme} samples={highlightedSamples} compact />
    </section>

    <section class="theme-gallery" aria-labelledby="themes-title">
      <div class="section-heading">
        <p>Theme variants</p>
        <h2 id="themes-title">VS Code themes</h2>
      </div>
      <div class="theme-grid">
        {themes.map((theme) => (
          <a class="theme-card" href={`/themes/${theme.slug}`}>
            <span class="theme-card-gradient" style={`background: linear-gradient(135deg, ${theme.colors["editor.background"]}, ${theme.colors["button.background"] ?? theme.syntax.keyword}, ${theme.colors["focusBorder"] ?? theme.syntax.function})`}></span>
            <span>
              <strong>{theme.name}</strong>
              <small>{theme.source} · {theme.type}</small>
            </span>
          </a>
        ))}
      </div>
    </section>

    <ApplicationPreviews applications={applications} />
    <Palette theme={featuredTheme} />
  </main>
</BaseLayout>
