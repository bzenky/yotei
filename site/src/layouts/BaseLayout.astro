---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yotei Theme Preview",
  description = "Preview the Yotei theme across editor UI, code samples, and terminal colors."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
